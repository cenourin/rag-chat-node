# Chave da API da Anthropic (obrigatória para respostas reais do Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo Claude usado para gerar as respostas
CLAUDE_MODEL=claude-sonnet-4-5

# Porta da API
PORT=3000

# Tamanho do chunk (em caracteres aproximados) e overlap entre chunks
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Quantidade de chunks recuperados por pergunta (top-K)
RETRIEVAL_TOP_K=4

# Tamanho máximo do histórico mantido em memória
HISTORY_MAX_ITEMS=50
